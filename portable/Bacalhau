#!/bin/bash
# Bacalhau — launch the manuscript editor.
# Place this file (and editor.py) in your project folder, then run it.
#
# Usage:
#   ./Bacalhau                  # open current directory
#   ./Bacalhau /path/to/project # open a specific directory
#
cd "$(dirname "$0")"
exec python3 "$(dirname "$0")/editor.py" "${1:-.}"
