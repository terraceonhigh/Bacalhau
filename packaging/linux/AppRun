#!/bin/bash
# Bacalhau AppImage entry point

EDITOR="$APPDIR/usr/bin/editor.py"
APPIMAGE_PARENT="$(dirname "${APPIMAGE:-$0}")"
PIDFILE="$HOME/.bacalhau.pid"

# Kill any existing instance
if [ -f "$PIDFILE" ]; then
    OLD_PID=$(cat "$PIDFILE" 2>/dev/null)
    if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
        kill "$OLD_PID" 2>/dev/null
        sleep 0.5
    fi
    rm -f "$PIDFILE"
fi

# Check for Python 3
if ! command -v python3 >/dev/null 2>&1; then
    echo "Error: Bacalhau requires Python 3, which was not found on your system." >&2
    exit 1
fi

# Project directory resolution
PROJECT=""
if [ -n "$1" ] && [ -f "$1" ] && echo "$1" | grep -q '\.bacalhau$'; then
    PROJECT="$1"
elif [ -d "$APPIMAGE_PARENT/chapters" ]; then
    PROJECT="$APPIMAGE_PARENT/chapters"
elif [ -d "$PWD/chapters" ]; then
    PROJECT="$PWD/chapters"
fi

# Launch and write PID file
python3 "$EDITOR" $PROJECT &
echo $! > "$PIDFILE"

trap "rm -f '$PIDFILE'" EXIT
wait
